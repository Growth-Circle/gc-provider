{
  "id": "gc-provider",
  "name": "GrowthCircle.id Provider",
  "version": "0.1.3",
  "description": "OpenAI-compatible GrowthCircle.id model provider for OpenClaw.",
  "extensions": ["./index.ts"],
  "providers": ["growthcircle"],
  "setup": {
    "requiresRuntime": false,
    "providers": [
      {
        "id": "growthcircle",
        "authMethods": ["api-key"],
        "envVars": ["GROWTHCIRCLE_API_KEY"]
      }
    ]
  },
  "providerAuthChoices": [
    {
      "provider": "growthcircle",
      "method": "api-key",
      "choiceId": "growthcircle-api-key",
      "choiceLabel": "GrowthCircle.id API key",
      "choiceHint": "Use a gc-free, gc-paid, or gc-team key.",
      "groupId": "growthcircle",
      "groupLabel": "GrowthCircle.id",
      "optionKey": "growthcircleApiKey",
      "cliFlag": "--growthcircle-api-key",
      "cliOption": "--growthcircle-api-key <key>",
      "cliDescription": "GrowthCircle.id API key.",
      "onboardingScopes": ["text-inference"]
    }
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  }
}
